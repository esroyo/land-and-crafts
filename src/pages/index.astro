---
import { getCollection } from 'astro:content';
import { title } from '../common.ts';

import CarouselGallery from '../components/CarouselGallery.astro';
import Logo from '../assets/land-and-crafts.svg';
import Layout from '../layouts/Layout.astro';
import LeafletMarker from '../components/LeafletMarker.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectDetails from '../components/ProjectDetails.astro';
import ProjectDetailsClose from '../components/ProjectDetailsClose.astro';

const projects = await getCollection('projects');
const coordinatesMax = projects.map(p => p.data.coordinates).reduce((acc, cur) => [Math.max(acc[0], cur[0]), Math.max(acc[1], cur[1])], [-Infinity, -Infinity]);
const coordinatesMin = projects.map(p => p.data.coordinates).reduce((acc, cur) => [Math.min(acc[0], cur[0]), Math.min(acc[1], cur[1])], [+Infinity, +Infinity]);
const coordinates = [((coordinatesMax[0] - coordinatesMin[0]) / 2) + coordinatesMin[0], ((coordinatesMax[1] - coordinatesMin[1]) / 2) + coordinatesMin[1]];
const backgroundColor = '#182121';
const secondaryBackgroundColor = '#324242';
---

<Layout>
    <main style={ `--backgroundColor: ${backgroundColor}; --secondaryBackgroundColor: ${secondaryBackgroundColor}` }>
        <header class="header" id="headerSection">
            <details id="headerDescription">
                <summary><Logo aria-labeld={ title } role="img" class="logo" /></summary>
            <p>Map of <em>site-specific</em> artifacts that explore the relationship between human beings and nature through biocentric and multispecies design. Each project generates an aesthetic experience integrated into the environment, through the use of local materials and traditional or contemporary artisan techniques.</p>
            </details>
        </header>
        <section class="sidebar" id="sidebarSection">
            { projects.map((project) => <ProjectCard { project } />) }
        </section>
        <section class="map" id="mapSection" data-initial-coordinates={ coordinates }>
            { projects.map((project) => <LeafletMarker { project } />) }
        </section>
        <section class="details hide" id="detailsSection">
            <ProjectDetailsClose />
            <div class="details-collection">
                { projects.map((project) => <ProjectDetails { project } />) }
            </div>
        </section>
    </main>
    <CarouselGallery />
</Layout>

<script>
    import { Map, TileLayer } from 'leaflet';
    import { TILES_URL, getZoom, isMobile } from '../common.ts';

    const map = new Map(mapSection).setView(mapSection.dataset.initialCoordinates.split(','), getZoom());
    const tile = new TileLayer(`${TILES_URL}/{z}/{x}/{y}.png`, {
      maxZoom: 19,
      attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
    }).addTo(map);

    // Open header description by default on desktop; closed on mobile.
    headerDescription.open = !isMobile();
</script>

<style>
main {
  height: 100%;
  display: grid;
  grid-template-columns: minmax(300px, 1fr) 1fr 1fr 1fr 1fr;
  grid-template-rows: auto 1fr;
  grid-template-areas:
    "header map map map map"
    "sidebar map map map map";

  & > section {
      max-height: 100dvh;
      overflow: auto;
  }
}

.header {
  grid-area: header;
  background: var(--backgroundColor);
  color: white;
  padding: 1rem;
  overflow: auto;
  scrollbar-color: #EEE var(--backgroundColor);

  .logo {
      fill: white;
      width: 100%;
      max-height: 3rem;
  }

  & p {
      font-size: .9rem;
      margin-top: 0;
  }

  details summary {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 1rem;
    cursor: pointer;

    .logo {
        flex: 1;
    }

    &::after {
        content: "i";
        flex-shrink: 0;
        width: 1.75rem;
        aspect-ratio: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: white;
        background-color: var(--secondaryBackgroundColor);
        font-family: serif;
        font-style: italic;
        font-weight: bold;
        margin-top: -0.5rem;
    }

    [open] &::after {
        content: "×";
        font-family: inherit;
        font-style: normal;
    }
  }
}

.sidebar {
  grid-area: sidebar;
  background: var(--backgroundColor);
  min-height: 0;
  overflow: auto;
  scrollbar-color: #EEE var(--backgroundColor);
}

.map {
  grid-area: map;
  background: #90CCCB;
  height: 100%;
  width: 100%;
}
.details-collection {
  height: 100%;
  overflow: auto;
}
.details {
  grid-area: 1 / 4 / 3 / 6;
  background: white;
  z-index: 1000; /* same as leaflet max */
  height: 100%;
  width: 100%;
  position: relative;
  transition: transform 0.3s ease;

  &.hide {
      transform: translateX(100dvw);
  }
}

@media (max-width: 768px) {
    main {
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr minmax(0, 60dvh);
        grid-template-areas:
            "header"
            "map"
            "sidebar";
    }

    .details {
        grid-area: 3 / 1 / 4 / 2;
        transition: transform 0.3s ease;
        &.hide {
            transform: translateY(100dvh);
        }
    }
}
</style>
